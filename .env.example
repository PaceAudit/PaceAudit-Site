# Claude API key (used for blog/article generation with humanizer)
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Gemini API keys (required for social posts, images; fallback if no Claude)
# Use two keys to maximize free tier quota: PRO for blog fallback, FLASH for social.
# Get keys at https://aistudio.google.com/apikey
GEMINI_PRO_KEY=your_pro_key_here
GEMINI_FLASH_KEY=your_flash_key_here
# Legacy fallback (used if PRO/FLASH not set):
# GOOGLE_GENERATIVE_AI_API_KEY=your_api_key_here
# GEMINI_API_KEY=your_api_key_here

# Optional: image generation endpoint URL (POST { "prompt": "..." } → { "url": "..." })
# Leave unset to skip image generation; content will still be saved with image_url = null.
# IMAGE_GENERATION_URL=https://your-image-api.com/generate

# --- Publishing (hourly cron): LinkedIn, Facebook, Meta/Instagram, X, Netlify ---
# Content is sent to: LinkedIn | Facebook | Meta (Instagram) | X (Twitter) | Netlify (GitHub + deploy hook).

# Netlify website: push blog HTML to the repo connected to Netlify, then trigger build
# Cron publish (Approve & Schedule): push approved posts to GitHub at blog/{slug}.html on scheduled date
# GITHUB_TOKEN=ghp_xxx
# GITHUB_OWNER=your-org
# GITHUB_REPO=your-repo
# Or use legacy names:
# GITHUB_REPO_OWNER=your-org
# GITHUB_REPO_NAME=your-repo
# GITHUB_CONTENT_PATH=content/post.html
# GITHUB_BRANCH=main
# Optional: Netlify deploy hook (Site settings → Build & deploy → Build hooks). Triggers deploy after GitHub push.
# NETLIFY_DEPLOY_HOOK=https://api.netlify.com/build_hooks/xxx
#
# Buildless Netlify publishing (recommended to save build minutes/credits):
# NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token
# NETLIFY_SITE_ID=your_netlify_site_api_id

# Vercel Cron: optional secret to authorize /api/cron and /api/cron/publish (Vercel adds x-vercel-cron automatically).
# CRON_SECRET=your_random_secret

# Turso (LibSQL) — production database. When set, Topics/Content/Config persist to Turso instead of local files.
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token

# X (Twitter): post first twitter_copy (twitter-api-v2)
# TWITTER_APP_KEY=xxx
# TWITTER_APP_SECRET=xxx
# TWITTER_ACCESS_TOKEN=xxx
# TWITTER_ACCESS_SECRET=xxx

# LinkedIn: post first linkedin_copy (REST Posts API)
# LINKEDIN_ACCESS_TOKEN=xxx
# LINKEDIN_PERSON_URN=urn:li:person:xxx

# Facebook & Meta (Instagram): same META_ACCESS_TOKEN; image must be public (SITE_URL or Content.image_url)
# SITE_URL=https://yoursite.com
# META_ACCESS_TOKEN=xxx
# FACEBOOK_PAGE_ID=xxx
# INSTAGRAM_ACCOUNT_ID=xxx
